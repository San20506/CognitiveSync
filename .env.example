# ============================================================
# CognitiveSync Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://cognitivesync:changeme@localhost:5432/cognitivesync
AUDIT_DATABASE_URL=postgresql+asyncpg://cognitivesync:changeme@localhost:5433/cognitivesync_audit

# --- JWT Authentication (RS256) ---
# Generate: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Pseudonymization ---
ORG_SALT=replace-with-32-char-random-hex-salt

# --- Encrypted ID Mapping Store ---
VAULT_KEY=replace-with-32-char-aes-master-key
VAULT_PATH=/vault/id_mapping.enc

# --- Pipeline ---
REFRESH_INTERVAL_HOURS=48
ALERT_THRESHOLD=0.75
CASCADE_THRESHOLD=0.70
CASCADE_ALERT_THRESHOLD=0.60
DECAY_FACTOR=0.60
MAX_HOPS=2
RETENTION_DAYS=90

# --- MS Graph Connector ---
MSGRAPH_CLIENT_ID=
MSGRAPH_CLIENT_SECRET=
MSGRAPH_TENANT_ID=

# --- Slack Connector ---
SLACK_BOT_TOKEN=xoxb-
SLACK_SIGNING_SECRET=

# --- GitHub Connector ---
GITHUB_ORG_TOKEN=ghp_
GITHUB_ORG_NAME=

# --- Power BI ---
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
POWERBI_TENANT_ID=
POWERBI_DATASET_ID=
POWERBI_WORKSPACE_ID=
POWERBI_DASHBOARD_URL=https://app.powerbi.com/...

# --- MS Teams Bot ---
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
TEAMS_HR_CHANNEL_ID=
# JSON map: {"team-uuid": "channel-id", ...}
TEAMS_MANAGER_CHANNEL_IDS={}

# --- Model Registry ---
MODEL_REGISTRY_PATH=/models
ACTIVE_MODEL_VERSION=latest

# --- Mode ---
# Set to "mock" to use synthetic data (no real API calls needed for dev/demo)
ADAPTER_MODE=mock
